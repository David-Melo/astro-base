---
import Layout from '../layouts/Layout.astro';
import { generateWebSiteSchema, combineSchemas } from '../utils/structuredData';

const meta = {
	title: "Site Home Title",
	description: "Site Home Description"
};

const siteUrl = Astro.site?.href || 'https://site.com';
const schemas = combineSchemas(
	generateWebSiteSchema(siteUrl)
);
---

<Layout title={meta.title} description={meta.description} jsonLd={schemas}>
	<h1 class="text-hero leading-tight">
		Welcome
	</h1>
</Layout>
